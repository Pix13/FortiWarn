# FortiWarn Configuration Template

# --- Fortinet Credentials ---
# Host: just the hostname[:port] — no scheme, no trailing slash.
# A full URL (https://host:port/) is also accepted; the scheme will be stripped.
FORTINET_HOST=fortinet.example.com:8443

# Authentication: provide EITHER an API key (recommended) OR username+password.
FORTINET_API_KEY=
#FORTINET_USERNAME=
#FORTINET_PASSWORD=

# Optional — only needed on multi-VDOM FortiGates.
#FORTINET_VDOM=root

# --- SDWAN Interface Names (from `get system sdwan` on the FortiGate) ---
MAIN_INTERFACE=wan1
BACKUP_INTERFACE=wan2

# --- Email Settings ---
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
# SMTP_USER / SMTP_PASSWORD are optional — leave blank for unauthenticated
# internal relays. If set, both must be set.
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=fortiwarn@example.com
EMAIL_TO=ops@example.com

# --- Daemon Settings ---
CHECK_INTERVAL_SECONDS=60
